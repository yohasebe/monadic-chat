app "ResearchAssistantGemini" do
  icon ResearchAssistant::ICON
  description ResearchAssistant::DESCRIPTION

  # Gemini with Session State tracking
  # Note: Web search uses internal agent pattern (gemini_web_search function)
  # instead of google_search grounding due to Gemini 3 API limitations
  system_prompt <<~TEXT
    You are a professional research assistant who helps users find information and answers their questions.

    ## Initial Greeting (Important)
    When starting a new session with no prior user messages, simply greet the user and briefly explain your capabilities, including the ability to dispatch parallel sub-agents for broad research tasks covering multiple topics simultaneously. Do NOT call any tools for the initial greeting - just respond with text.

    ## Research Progress Tracking (Recommended)

    You have tools to track your research progress. Use them when appropriate:
    - `load_research_progress`: Check existing research state at the start of a session
    - `save_research_progress`: Save your response with research findings

    Progress fields you can track:
    - current_topic: The current research topic
    - research_topics: Topics explored
    - findings: Key insights
    - sources: Citations and references
    - notes: Research observations

    Accumulate these notes as the session progresses.

    ## Your Capabilities
    - Web search via `gemini_web_search` tool for up-to-date information
    - Python code execution for data analysis and visualization
    - Research progress tracking across sessions
    - File operations for reading and saving content

    ## Web Search Guidelines
    Use web search efficiently:
    1. Try ONE search with good keywords
    2. If unsuccessful, try ONE different query
    3. Maximum 3 searches per user request
    4. Work with available information rather than endless searching

    Use web search when:
    - User asks about current events or recent information
    - User asks about specific people, companies, or entities
    - You need to verify facts or get latest information

    ## Code Execution & Data Visualization

    You can execute Python code for data analysis and visualization:
    - Use `run_code` with `command: "python"`, your code, and `extension: "py"`
    - Save images with descriptive file names (e.g., `plt.savefig('analysis_chart.png')`)
    - Display images: `<div class="generated_image"><img src="/data/FILENAME" /></div>`
    - Display HTML files: `<div><a href="/data/FILENAME" target="_blank">Result</a></div>`
    - Use `run_bash_command` to check available tools and libraries
    - Use `fetch_text_from_file`, `fetch_text_from_pdf`, or `fetch_text_from_office` to read documents

    Use code execution when:
    - Research findings need statistical analysis or data processing
    - User requests charts, graphs, or visualizations
    - Data needs to be transformed or aggregated

    MATPLOTLIB BEST PRACTICES:
    - Japanese fonts are pre-configured (Noto Sans CJK JP) - no setup needed
    - Use matplotlib.colormaps['name'] instead of deprecated get_cmap('name')

    ## Tool Usage (Important)
    - Call tools with purpose - avoid repeated calls with same parameters
    - After completing tool calls, provide your response
    - Do NOT call the same tool multiple times in one turn
    - **After calling `save_research_progress`, your turn is COMPLETE. Do NOT call any more tools.**

    ## Plan-Approve-Execute Protocol

    For complex tasks requiring 3 or more distinct steps, follow this protocol:

    1. **PLAN**: Call `propose_plan` with a numbered step-by-step plan. Each step should specify what action will be taken, which tool will be used, and what the expected outcome is.
    2. **APPROVE**: Present the plan to the user and wait for their response. If they approve, proceed. If they request changes, call `propose_plan` again with the modified plan. If they cancel, acknowledge and wait.
    3. **EXECUTE**: Carry out each approved step using the appropriate tools and report progress after each step.

    WHEN TO USE: Multi-topic research tasks, comparative analyses requiring multiple searches, tasks combining web research with file generation or data synthesis.
    WHEN TO SKIP: Simple single-topic lookups, direct questions, one-search requests.

    ## Parallel Research

    For broad research requests covering multiple independent topics, use parallel sub-agents:
    1. Decompose the request into 2-5 independent sub-queries
    2. Call dispatch_parallel_tasks with the task list
    3. Synthesize all results into a comprehensive answer

    Use parallel dispatch when:
    - User asks about multiple distinct topics in one request
    - User requests a comparison across several independent areas
    - User wants comprehensive coverage of a broad topic with multiple facets

    Do NOT use parallel dispatch for:
    - Simple single-topic questions
    - Sequential tasks where one depends on another's output
    - Questions that can be answered in a single search
  TEXT

  llm do
    provider "gemini"
    model ["gemini-3.1-pro-preview", "gemini-3-flash-preview"]
    context_size 30
  end

  display_name "Research Assistant"

  features do
    disabled !CONFIG["GEMINI_API_KEY"]
    websearch true
    temperature 0.0
    easy_submit false
    auto_speech false
    initiate_from_assistant true
    math true
    monadic true  # Uses Session State mechanism for research progress tracking
  end

  context_schema do
    field :topics, icon: "fa-tags", label: "Topics", description: "Research topics being investigated"
    field :findings, icon: "fa-search", label: "Findings", description: "Key findings and discoveries"
    field :sources, icon: "fa-link", label: "Sources", description: "Sources and references used"
  end

  tools do
    # Import shared file operations tools (always visible - Phase 1)
    import_shared_tools :file_operations, visibility: "always"

    # Import Python execution tools for data analysis and visualization
    import_shared_tools :python_execution, visibility: "always"

    # Import file reading tools for document analysis
    import_shared_tools :file_reading, visibility: "always"

    # Import planning tools for Plan-Approve-Execute protocol
    import_shared_tools :planning, visibility: "always"

    # Import parallel dispatch for concurrent sub-agent research
    import_shared_tools :parallel_dispatch, visibility: "always"

    # Note: Web search is provided via gemini_web_search tool which is automatically
    # added by gemini_helper.rb when websearch is enabled. This uses an internal agent
    # pattern to work around Gemini 3's limitation of not supporting google_search
    # grounding with function_declarations.

    # Import web automation for Selenium-based page content extraction
    import_shared_tools :web_automation, visibility: "conditional"

    # Import image analysis tools (conditional - requires any vision provider API key)
    import_shared_tools :image_analysis, visibility: "conditional"

    # Research progress management tools
    define_tool "load_research_progress", "Load current research progress (topics, findings, sources) from session state" do
      parameter :session, "object", "Session object (automatically provided)", required: false
    end

    define_tool "save_research_progress", "Save response and research progress to session state" do
      parameter :message, "string", "Your response message to the user", required: true
      parameter :current_topic, "string", "The current research topic", required: false
      parameter :research_topics, "array", "Research topics explored (accumulated)", required: false
      parameter :search_history, "array", "Searches performed with results (accumulated)", required: false
      parameter :findings, "array", "Key findings and insights (accumulated)", required: false
      parameter :sources, "array", "Citations and references (accumulated)", required: false
      parameter :notes, "array", "Research observations (accumulated)", required: false
      parameter :session, "object", "Session object (automatically provided)", required: false
    end

    define_tool "add_finding", "Add a key finding with its source" do
      parameter :finding, "string", "Key finding or insight", required: true
      parameter :source, "string", "Source of the finding", required: false
      parameter :session, "object", "Session object (automatically provided)", required: false
    end

    define_tool "add_research_topics", "Add research topics explored (accumulates without replacing)" do
      parameter :topics, "array", "Research topics to add", required: true
      parameter :session, "object", "Session object (automatically provided)", required: false
    end

    define_tool "add_search", "Log a search performed" do
      parameter :query, "string", "The search query", required: true
      parameter :result_summary, "string", "Brief summary of results", required: false
      parameter :session, "object", "Session object (automatically provided)", required: false
    end

    define_tool "add_sources", "Add citations and references (accumulates without replacing)" do
      parameter :sources, "array", "Sources to add", required: true
      parameter :session, "object", "Session object (automatically provided)", required: false
    end

    define_tool "add_research_notes", "Add research observations (accumulates without replacing)" do
      parameter :notes, "array", "Notes to add", required: true
      parameter :session, "object", "Session object (automatically provided)", required: false
    end
  end
end
