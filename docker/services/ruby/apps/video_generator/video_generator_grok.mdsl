app "VideoGeneratorGrok" do
  description do
    en <<~TEXT
    Generate videos from text descriptions. <a href="https://yohasebe.github.io/monadic-chat/#/basic-usage/basic-apps?id=video-generator" target="_blank"><i class="fa-solid fa-circle-info"></i></a>
    TEXT

    ja <<~TEXT
    テキスト説明からビデオ生成。 <a href="https://yohasebe.github.io/monadic-chat/#/basic-usage/basic-apps?id=video-generator" target="_blank"><i class="fa-solid fa-circle-info"></i></a>
    TEXT

    zh <<~TEXT
    从文本描述生成视频。 <a href="https://yohasebe.github.io/monadic-chat/#/basic-usage/basic-apps?id=video-generator" target="_blank"><i class="fa-solid fa-circle-info"></i></a>
    TEXT

    ko <<~TEXT
    텍스트 설명에서 비디오 생성. <a href="https://yohasebe.github.io/monadic-chat/#/basic-usage/basic-apps?id=video-generator" target="_blank"><i class="fa-solid fa-circle-info"></i></a>
    TEXT

    es <<~TEXT
    Generar videos desde descripciones de texto. <a href="https://yohasebe.github.io/monadic-chat/#/basic-usage/basic-apps?id=video-generator" target="_blank"><i class="fa-solid fa-circle-info"></i></a>
    TEXT

    fr <<~TEXT
    Générer des vidéos à partir de descriptions textuelles. <a href="https://yohasebe.github.io/monadic-chat/#/basic-usage/basic-apps?id=video-generator" target="_blank"><i class="fa-solid fa-circle-info"></i></a>
    TEXT

    de <<~TEXT
    Videos aus Textbeschreibungen generieren. <a href="https://yohasebe.github.io/monadic-chat/#/basic-usage/basic-apps?id=video-generator" target="_blank"><i class="fa-solid fa-circle-info"></i></a>
    TEXT
  end

  icon "fa-solid fa-film"

  display_name "Video Generator"

  llm do
    provider "xai"
    temperature 0.0
    context_size 10
  end

  system_prompt <<~TEXT
    You help users create videos using xAI's Grok Imagine Video model.
    Specs: 480p/720p, 1-15 seconds, aspect ratios 16:9/9:16/1:1, native audio.
    Capabilities: text-to-video only. The xAI API does NOT accept image
    uploads for video generation — if the user attaches an image, treat
    it purely as visual reference for crafting a richer text prompt and
    do not pass image_path to the tool. (Use Gemini Veo if true
    image-to-video is required.)

    GREETING: If this is the very first turn of a brand-new conversation
    and the user has not yet submitted any actual request, you may briefly
    introduce yourself in 1-2 sentences. In every other case, do NOT
    re-emit a greeting — respond to the user's actual request by calling
    the appropriate tool.

    WORKFLOW:

    1. **Text-to-Video (the only supported flow):**
       - User describes a video → call generate_video_with_grok_imagine(prompt: "...")
       - Pass user's prompt unchanged
       - If the user uploaded an image, describe its contents in the prompt
         (e.g., "a green Ibanez electric guitar with maple fretboard ...");
         do NOT include image_path

    PARAMETER DETECTION:
    - Duration: 1-15 seconds (default: 5)
    - Aspect ratio: 16:9 (default), 9:16 (vertical/portrait), 1:1 (square)
    - Resolution: 720p (default), 480p (for faster generation)

    RESULT DISPLAY:
    Success - Output raw HTML (NO markdown code blocks):
    <div class="prompt" style="margin-bottom: 15px;">
      <b>Prompt</b>: [user's prompt]
    </div>
    <div class="generated_video">
      <video controls width="600">
        <source src="/data/[filename]" type="video/mp4" />
      </video>
    </div>

    Error:
    <div class="error-message" style="background-color: #ffebee; color: #c62828; padding: 15px; border-radius: 5px; margin: 10px 0;">
      <b>Video Generation Failed</b><br/>
      [error message]
    </div>

    CRITICAL - NO CONTENT FILTERING:
    - Your role is ONLY to facilitate video generation, NOT to judge content
    - Pass user's prompt EXACTLY as provided - do not modify, censor, or filter
    - Do NOT refuse requests based on content - the video generation model handles its own moderation
    - Do NOT add safety disclaimers or warnings about content
    - Simply relay the user's request to the video generation tool

    RULES:
    - Always call tools for video operations
    - Do not modify user's prompt
    - Never pass image_path to generate_video_with_grok_imagine — the
      xAI API rejects image uploads with HTTP 400
    - NEVER retry automatically on error
    - Video generation may take several minutes

    ## Plan-Approve-Execute Protocol

    For complex tasks requiring 3 or more distinct steps, follow this protocol:

    1. **PLAN**: Call `propose_plan` with a numbered step-by-step plan. Each step should specify what action will be taken, which tool will be used, and what the expected outcome is.
    2. **APPROVE**: Present the plan to the user and wait for their response. If they approve, proceed. If they request changes, call `propose_plan` again with the modified plan. If they cancel, acknowledge and wait.
    3. **EXECUTE**: Carry out each approved step using the appropriate tools and report progress after each step.

    WHEN TO USE: Multi-video generation projects, iterative prompt refinement with style variations.
    WHEN TO SKIP: Single video generation, quick prompt-to-video.
  TEXT

  features do
    library_save false
    library_search false
    disabled !CONFIG["XAI_API_KEY"]
    easy_submit false
    auto_speech false
    initiate_from_assistant true
    image_generation "upload_only"
    video_generation true
    monadic true
    group "xAI"
  end

  context_schema do
    field :styles, icon: "fa-palette", label: "Styles", description: "Visual styles and preferences"
    field :prompts, icon: "fa-pen", label: "Prompts", description: "Key video descriptions used"
    field :notes, icon: "fa-sticky-note", label: "Notes", description: "Important preferences to remember"
  end

  tools do
    # Import planning tools for Plan-Approve-Execute protocol
    import_shared_tools :planning, visibility: "always"

    define_tool "generate_video_with_grok_imagine", "Generate 1-15 second videos using xAI's Grok Imagine Video model (480p or 720p, with native audio)." do
      parameter :prompt, "string", "The prompt to generate a video from (should be descriptive for best results).", required: true
      parameter :duration, "integer", "Video duration in seconds (1-15, default: 5).", required: false
      parameter :aspect_ratio, "string", "Aspect ratio: '16:9' (default), '9:16' (vertical), '1:1' (square).", required: false
      parameter :resolution, "string", "Resolution: '720p' (default) or '480p'.", required: false
      parameter :image_path, "string", "Optional: Filename of image in the shared folder for image-to-video generation (e.g., 'photo.jpg').", required: false
      parameter :session, "object", "Session object (automatically provided)", required: false
    end

    define_tool "monadic_load_state", "Load monadic session state for this app/key. Use this to retrieve the last used image filename for reuse." do
      parameter :app, "string", "App name (defaults to current app)", required: false
      parameter :key, "string", "State key to load", required: true
      parameter :default, "object", "Default value if state is missing", required: false
      parameter :session, "object", "Session object (automatically provided)", required: false
    end
  end
end
